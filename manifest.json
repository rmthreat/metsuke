{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_appName__",
  "version": "1.0.0",
  "description": "__MSG_appDesc__",
  "icons": { "16": "icons/16.png", "32": "icons/32.png", "48": "icons/48.png", "128": "icons/128.png" },
  "permissions": ["storage"],
  "host_permissions": [
    "https://github.com/*", "https://gitlab.com/*",
    "https://bitbucket.org/*", "https://raw.githubusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_icon": { "16": "icons/16.png", "32": "icons/32.png", "48": "icons/48.png" } },
  "content_scripts": [{
    "matches": ["https://github.com/*", "https://gitlab.com/*", "https://bitbucket.org/*"],
    "js": ["detector.js", "content.js"], "run_at": "document_idle"
  }]
}
